rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /profiles/{userId} {
      // السماح بالقراءة والتحديث للمالك
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      
      // السماح بالتحديث للمالك أو إذا كانت العملية تحديثاً لترقية الحساب (في النماذج الأولية نسهل القاعدة)
      // ملاحظة: في الإنتاج يفضل استخدام Firebase Admin SDK في الـ Webhook لتجاوز القواعد كلياً
      allow update: if isOwner(userId) || (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPro', 'credit_balance', 'updatedAt']));

      match /lessonPlans/{planId} {
        allow read, write: if isOwner(userId);
      }
      match /usage_logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
      }
      match /credit_transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) || (request.auth == null);
      }
    }
  }
}
