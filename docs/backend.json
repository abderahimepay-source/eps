
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information, account status, and aggregated statistics.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Unique identifier for the UserProfile, matching Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "isPro": {
          "type": "boolean"
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the user has administrative privileges."
        },
        "credit_balance": {
          "type": "number"
        },
        "totalLessonPlansCreated": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "uid",
        "email",
        "displayName",
        "isPro",
        "isAdmin",
        "credit_balance",
        "totalLessonPlansCreated",
        "createdAt"
      ]
    },
    "UsageLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UsageLog",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "aiFeatureUsed": { "type": "string" },
        "tokensConsumed": { "type": "number" },
        "creditsBurned": { "type": "number" },
        "modelMultiplier": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CreditTransaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "CreditTransaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "transactionType": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/profiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile document."
        }
      },
      {
        "path": "/profiles/{userId}/usage_logs/{logId}",
        "definition": {
          "entityName": "UsageLog",
          "schema": { "$ref": "#/backend/entities/UsageLog" },
          "description": "AI usage logs."
        }
      },
      {
        "path": "/profiles/{userId}/credit_transactions/{transactionId}",
        "definition": {
          "entityName": "CreditTransaction",
          "schema": { "$ref": "#/backend/entities/CreditTransaction" },
          "description": "Credit balance history."
        }
      }
    ]
  }
}
